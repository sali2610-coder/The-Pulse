# --- Optional legacy fan-out ---
# Mirror manual expense entries to an external endpoint. Silent no-op
# when unset. Canonical ingestion path is /api/webhooks/transactions.
NEXT_PUBLIC_EXPENSE_ENDPOINT=

# --- Webhooks (single-user / legacy mode only) ---
# Bearer token accepted by /api/webhooks/transactions when no Personal
# API Token is present. Multi-user installs (Supabase Auth enabled)
# accept only stk_… tokens and ignore this value.
WEBHOOK_SECRET=

# --- Supabase Auth + cloud sync ---
# Sole identity provider since Phase 152b. URL is the project base URL
# (NOT the /rest/v1 URL). Anon key is RLS-gated; safe to ship to the
# client. Service-role key is NEVER read by this codebase.
# NEXT_PUBLIC_SUPABASE_KEY is accepted as a legacy alias for the anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional. Used ONLY as a server-rendered fallback when window is
# unavailable (SSR). The browser always prefers window.location.origin
# so local dev never leaks to the production origin.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ⚠ Supabase dashboard requirement — Authentication → URL Configuration:
#   - Site URL:      production canonical (https://the-pulse-sooty.vercel.app)
#   - Redirect URLs: add EVERY host the app runs on, including the
#                    /api/auth/callback path:
#                      http://localhost:3000/api/auth/callback
#                      https://the-pulse-sooty.vercel.app/api/auth/callback
#                      https://*-yourteam.vercel.app/api/auth/callback   (preview, optional)
#   If a host is missing from Redirect URLs, Supabase silently ignores
#   our redirectTo and 302s the user to the Site URL root with ?code=
#   attached. src/proxy.ts has a middleware safety net that catches
#   "?code on /" and forwards to /api/auth/callback on the host the
#   user is currently browsing — but that ONLY rescues the flow when
#   Supabase fell back to a Site URL that matches the user's host.
#   For local dev to land on localhost after Google, the localhost
#   callback URL MUST be in the allow list.

# --- Vercel KV (Upstash Redis) ---
# Auto-provisioned by the Vercel Marketplace integration. Required for
# webhook ingestion + auto-sync + state-blob persistence.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
# Public key MUST also be exposed via NEXT_PUBLIC_VAPID_PUBLIC_KEY so the
# client can subscribe. iOS Safari requires the PWA to be installed
# (Add to Home Screen) before push permissions can be granted.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Open Banking (scaffolding only) ---
# Selects which provider module to load from src/lib/providers/. Only
# `mock` is implemented today — Plaid/Israeli aggregators await an
# authorised TPP relationship.
OPEN_BANKING_PROVIDER=mock

# Phase 386 — Receipt scan AI. Required for the "סריקה" button in
# the Add Expense flow. Without it /api/receipt/scan returns 503.
ANTHROPIC_API_KEY=sk-ant-...
