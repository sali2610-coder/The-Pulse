# --- Optional legacy fan-out ---
# Mirror manual expense entries to an external endpoint. Silent no-op
# when unset. Canonical ingestion path is /api/webhooks/transactions.
NEXT_PUBLIC_EXPENSE_ENDPOINT=

# --- Webhooks (single-user / legacy mode only) ---
# Bearer token accepted by /api/webhooks/transactions when no Personal
# API Token is present. Multi-user installs (Supabase Auth enabled)
# accept only stk_… tokens and ignore this value.
WEBHOOK_SECRET=

# --- Supabase Auth + cloud sync ---
# Sole identity provider since Phase 152b. URL is the project base URL
# (NOT the /rest/v1 URL). Anon key is RLS-gated; safe to ship to the
# client. Service-role key is NEVER read by this codebase.
# NEXT_PUBLIC_SUPABASE_KEY is accepted as a legacy alias for the anon key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Vercel KV (Upstash Redis) ---
# Auto-provisioned by the Vercel Marketplace integration. Required for
# webhook ingestion + auto-sync + state-blob persistence.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
# Public key MUST also be exposed via NEXT_PUBLIC_VAPID_PUBLIC_KEY so the
# client can subscribe. iOS Safari requires the PWA to be installed
# (Add to Home Screen) before push permissions can be granted.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Open Banking (scaffolding only) ---
# Selects which provider module to load from src/lib/providers/. Only
# `mock` is implemented today — Plaid/Israeli aggregators await an
# authorised TPP relationship.
OPEN_BANKING_PROVIDER=mock
