NEXT_PUBLIC_EXPENSE_ENDPOINT=https://example.com/api/expenses

# --- Webhooks (Open Banking ingestion) ---
# HMAC-SHA256 secret used to verify incoming /api/webhooks/transactions.
# Leave unset to disable the route (returns 503).
WEBHOOK_SECRET=

# --- Auth (Clerk) ---
# Auth is OFF unless ALL three are set:
NEXT_PUBLIC_AUTH_ENABLED=false
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: redirect URLs after sign-in/sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- Open Banking (Plaid sandbox example) ---
OPEN_BANKING_PROVIDER=plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Vercel KV (Upstash Redis) ---
# Auto-provisioned by the Vercel Marketplace integration. Required for
# webhook ingestion + auto-sync to actually persist between requests.
KV_REST_API_URL=
KV_REST_API_TOKEN=
