NEXT_PUBLIC_EXPENSE_ENDPOINT=https://example.com/api/expenses

# --- Webhooks (single-user / legacy mode only) ---
# Used when NEXT_PUBLIC_AUTH_ENABLED=false. In multi-user mode the webhook
# accepts only Personal API Tokens and this value is ignored.
WEBHOOK_SECRET=

# --- Auth (Clerk, multi-user) ---
# Set NEXT_PUBLIC_AUTH_ENABLED=true to switch into multi-user mode. KV keys
# move from sally:device:<deviceId>:* to sally:user:<userId>:*; the dashboard
# requires a Clerk session; the webhook accepts only Personal API Tokens.
NEXT_PUBLIC_AUTH_ENABLED=false
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: redirect URLs after sign-in/sign-up.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- Open Banking (Plaid sandbox example) ---
OPEN_BANKING_PROVIDER=plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# --- Vercel KV (Upstash Redis) ---
# Auto-provisioned by the Vercel Marketplace integration. Required for
# webhook ingestion + auto-sync to actually persist between requests.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Web Push (VAPID) ---
# Generate with: npx web-push generate-vapid-keys
# Public key is also exposed to the client as NEXT_PUBLIC_VAPID_PUBLIC_KEY.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Supabase (Phase 146+) ---
# Both vars must be set to enable Supabase-backed cloud sync.
# When either is missing, the app keeps working in local-first
# mode and the sync processor is a silent no-op.
# URL: https://app.supabase.com/project/<id>/settings/api → Project URL
# Anon key: same screen → "anon public" key (RLS-gated; safe to ship).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
