# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# claude code local settings
.claude/

# Playwright artifacts
test-results/
playwright-report/

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local

# Phase 164: perf-budget snapshot is per-build, not checked in.
perf-budget.snapshot.json

# Capacitor native shells (Phase 202)
# Generated locally via `npx cap add ios|android`. Native sources
# are committed only after a deliberate promotion — out of repo by
# default to keep CI + Vercel build paths clean.
/ios
/android

# Phase 395 — local E2E run output (screenshots + debug dumps).
e2e-output/
